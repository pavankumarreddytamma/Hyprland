{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["cpu", "temperature", "custom/gpu", "clock", "memory"],
    "modules-right": [
         "battery", "pulseaudio", "backlight", "network", "bluetooth", "custom/power"
    ],

    "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "persistent-workspaces": {
      "*": 4
    }
  },


    "hyprland/window": {
        "format": "{title}",
        "max-length": 40,
        "separate-outputs": true,
        "tooltip": false
    },

    "cpu": {
        "interval": 10,
        "format": "ΎΤ╝ {usage}%",
        "max-length": 10,
        "on-click": "kitty -e btop"
    },

    //"custom/gpu": {
        //"exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits", // or amd equivalent
        //"format": "≤░λχ {}%",
        //"interval": 10,
        //"on-click": "kitty -e nvtop",
        //"tooltip": false
    //},

    "memory": {
        "interval": 30,
        "format": "ΎΔΚ {used:0.1f}G",
        "max-length": 10,
        "on-click": "kitty -e btop",
        "tooltip": false
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"],
        "on-click": "kitty -e nvtop",
        "tooltip": false
        
    },

    "clock": {
        "format": "{:%I:%M %p   %d/%m/%y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

"battery": {
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "≤▒ΡΜ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "tooltip-format": "{capacity}% - {timeTo}"
},

    "network": {
        "format-wifi": "ΎΘτ  {essid} ({signalStrength}%)",
        "format-ethernet": "≤░ΙΑ {ifname}",
        "format-disconnected": "≤░Ψς Offline",
        "tooltip-format": "{ipaddr}"
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "≤░ζθ Muted",
        "format-icons": { "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"] },
        "on-click": "pavucontrol"
    },

    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["≤░Δη", "≤░Δθ", "≤░Δι"],
        "tooltip": false
    },

    "bluetooth": {
        "format": "ΎΛΥ {status}",
        "format-connected": "ΎΛΥ {device_alias}",
        "on-click": "blueman-manager"
    },

    "custom/power": {
        "format": "έΠ╗",
        "on-click": "wlogout",
        "tooltip": false
    }
}